{
  "ReverseProxy": {
    "Routes": {
      "studentRoute": {
        "ClusterId": "studentCluster",
        "Match": {
          "Path": "/api/students/{**catch-all}"
        }
      },
      "courseRoute": {
        "ClusterId": "courseCluster",
        "Match": {
          "Path": "/api/courses/{**catch-all}"
        }
      },
      "enrollmentRoute": {
        "ClusterId": "enrollmentCluster",
        "Match": {
          "Path": "/api/enrollments/{**catch-all}"
        }
      },
      "notificationRoute": {
        "ClusterId": "notificationCluster",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        }
      },
      "auditLogsRoute": {
        "ClusterId": "enrollmentCluster",
        "Match": {
          "Path": "/api/AuditLogs/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "studentCluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5001/" }
        }
      },
      "courseCluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5002/" }
        }
      },
      "enrollmentCluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5003/" }
        }
      },
      "notificationCluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5004/" }
        }
      }
    }
  }
}